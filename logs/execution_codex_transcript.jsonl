{"type":"item.started","item":{"id":"item_92","type":"command_execution","command":"/bin/bash -lc \"source .venv/bin/activate && python - <<'PY'\nimport json\nfrom pathlib import Path\nimport numpy as np\nimport pandas as pd\nfrom sklearn.model_selection import GroupKFold\nfrom sklearn.pipeline import Pipeline\nfrom sklearn.preprocessing import LabelEncoder, StandardScaler\nfrom sklearn.decomposition import PCA\nfrom sklearn.multiclass import OneVsRestClassifier\nfrom sklearn.linear_model import LogisticRegression\nfrom sklearn.base import clone\nfrom sklearn.metrics import accuracy_score\n\nroot = Path('/workspaces/llm-reading-modes-af09-codex')\ncustom = pd.read_json(root / 'results/custom_mode_predictions.jsonl', lines=True)\nids = custom['id'].tolist()\nembeds = []\nfor text_id in ids:\n    payload = json.loads((root / 'results/cache/embeddings' / f'{text_id}.json').read_text())\n    embeds.append(payload['embedding'])\nX = np.array(embeds, dtype=float)\ny_labels = custom['mode'].to_numpy()\ngroups = custom['anchor_id'].to_numpy()\nle = LabelEncoder().fit(['human_original','llm_generated','llm_humanized','human_polished','dictated_spoken','keyboard_noisy'])\ny = le.transform(y_labels)\n\nestimator = Pipeline([\n    ('scaler', StandardScaler()),\n    ('pca', PCA(n_components=0.95, random_state=42)),\n    ('clf', OneVsRestClassifier(LogisticRegression(max_iter=2000, solver='liblinear'))),\n])\n\ndef grouped_cv_predictions(X, y, groups, estimator):\n    cv = GroupKFold(n_splits=min(5, len(np.unique(groups))))\n    preds = np.empty(len(y), dtype=int)\n    for train_idx, test_idx in cv.split(X, y, groups):\n        model = clone(estimator)\n        model.fit(X[train_idx], y[train_idx])\n        preds[test_idx] = model.predict(X[test_idx])\n    return preds\n\nobs_preds = grouped_cv_predictions(X, y, groups, estimator)\nobs = accuracy_score(y, obs_preds)\nprint('observed', obs)\ncv = GroupKFold(n_splits=min(5, len(np.unique(groups))))\nrng = np.random.default_rng(42)\nscores = []\nfor i in range(10):\n    permuted = rng.permutation(y)\n    fold_preds = np.empty(len(y), dtype=int)\n    for train_idx, test_idx in cv.split(X, y, groups):\n        model = clone(estimator)\n        model.fit(X[train_idx], permuted[train_idx])\n        fold_preds[test_idx] = model.predict(X[test_idx])\n    score = accuracy_score(y, fold_preds)\n    scores.append(score)\n    print('perm', i, score)\np = (sum(s >= obs for s in scores) + 1) / (len(scores) + 1)\nprint('p', p)\nsummary_path = root / 'results/summary.json'\nsummary = json.loads(summary_path.read_text())\nsummary['embedding_probe']['permutation_p'] = p\nsummary['embedding_probe']['permutation_scores'] = scores\nsummary_path.write_text(json.dumps(summary, indent=2))\nprint('updated summary')\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
