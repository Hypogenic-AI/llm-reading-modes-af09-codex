)\nscores = []\nfor i in range(10):\n    permuted = rng.permutation(y)\n    fold_preds = np.empty(len(y), dtype=int)\n    for train_idx, test_idx in cv.split(X, y, groups):\n        model = clone(estimator)\n        model.fit(X[train_idx], permuted[train_idx])\n        fold_preds[test_idx] = model.predict(X[test_idx])\n    score = accuracy_score(y, fold_preds)\n    scores.append(score)\n    print('perm', i, score)\np = (sum(s >= obs for s in scores) + 1) / (len(scores) + 1)\nprint('p', p)\nsummary_path = root / 'results/summary.json'\nsummary = json.loads(summary_path.read_text())\nsummary['embedding_probe']['permutation_p'] = p\nsummary['embedding_probe']['permutation_scores'] = scores\nsummary_path.write_text(json.dumps(summary, indent=2))\nprint('updated summary')\nPY\"","aggregated_output":"observed 0.4888888888888889\nperm 0 0.1638888888888889\nperm 1 0.19444444444444445\nperm 2 0.16111111111111112\nperm 3 0.1527777777777778\nperm 4 0.1638888888888889\nperm 5 0.14444444444444443\nperm 6 0.14166666666666666\nperm 7 0.17222222222222222\nperm 8 0.19444444444444445\nperm 9 0.15\np 0.09090909090909091\nupdated summary\n","exit_code":0,"status":"completed"}}
